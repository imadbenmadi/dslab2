# PCNME core settings

# Compute
FOG_MIPS=2000
CLOUD_MIPS=8000
EC_THRESHOLD=1.0
Q_MAX=50

# Network
BANDWIDTH_MBPS=100.0
FOG_CLOUD_BW=1000.0
FOG_FOG_BW=100.0
WAN_LATENCY_MS=30.0
G5_LATENCY_MS=2.0
SDN_PREINSTALL_MS=0.0
SDN_REACTIVE_MS=12.0

# Fog coverage
FOG_COVERAGE_RADIUS=250.0

# NSGA-II + MMDE
NSGA_POP_SIZE=100
NSGA_GENS=200
MMDE_F=0.5
MMDE_CR=0.9
NSGA_BATCH_SIZE=100
N_OFFLINE_BATCHES=1000

# DQN Agent 1 (placement)
AGENT1_STATE_DIM=13
AGENT1_ACTION_DIM=5
AGENT1_HIDDEN=256,128
AGENT1_LR=0.001
AGENT1_GAMMA=0.95
AGENT1_EPSILON_START=0.30
AGENT1_EPSILON_END=0.05
AGENT1_EPSILON_DECAY=10000
AGENT1_BATCH_SIZE=64
AGENT1_BUFFER_SIZE=50000
AGENT1_TARGET_UPDATE=1000

# DQN Agent 2 (SDN routing)
AGENT2_STATE_DIM=15
AGENT2_ACTION_DIM=5
AGENT2_HIDDEN=256,128
AGENT2_LR=0.001
AGENT2_GAMMA=0.95
AGENT2_EPSILON_START=0.25
AGENT2_EPSILON_END=0.05
AGENT2_EPSILON_DECAY=8000
AGENT2_BATCH_SIZE=64
AGENT2_BUFFER_SIZE=50000
AGENT2_TARGET_UPDATE=1000

# Rewards
AGENT1_REWARD_LATENCY=0.5
AGENT1_REWARD_ENERGY=0.3
AGENT1_REWARD_VIOLATION=0.2
AGENT1_DEADLINE_PENALTY=10.0
AGENT2_REWARD_DELIVERY=0.5
AGENT2_REWARD_DELAY=0.3
AGENT2_REWARD_OVERHEAD=0.2
AGENT2_PACKET_DROP_PENALTY=50.0
AGENT2_PREINSTALL_BONUS=0.3

# Simulation
N_VEHICLES=50
VEHICLE_SPEED_MEAN=60.0
VEHICLE_SPEED_STD=15.0
TASK_RATE_HZ=10.0
SIM_DURATION_S=600.0
WARMUP_S=60.0
RANDOM_SEED=42
N_RUNS=5

# Storage
REDIS_URL=redis://localhost:6379/0

# Optional TimescaleDB (asyncpg DSN)
# TIMESCALE_DSN=postgresql://user:password@localhost:5432/pcnme

# Runtime
API_HOST=127.0.0.1
API_PORT=8080
WS_PATH=/ws/stream

# Optional runtime agents (enable inference during simulation)
# AGENT1_MODEL_PATH=results/agent1.pt
# AGENT2_MODEL_PATH=results/agent2.pt
