# Copy this file to .env and customize values for your deployment.

# Core topology and runtime
N_VEHICLES=50
SIM_DURATION_S=600
WARMUP_S=60
TASK_RATE_HZ=10
RANDOM_SEED=42

# Network/system
FOG_MIPS=2000
CLOUD_MIPS=8000
EC_THRESHOLD=1.0
BANDWIDTH_MBPS=100
FOG_CLOUD_BW=1000
FOG_FOG_BW=100
WAN_LATENCY_MS=30
G5_LATENCY_MS=2
FOG_COVERAGE_RADIUS=250
Q_MAX=50
TOTAL_DEADLINE_MS=200

# NSGA/MMDE
NSGA_POP_SIZE=50
NSGA_GENS=50
MMDE_F=0.5
MMDE_CR=0.9
NSGA_BATCH_SIZE=100
N_OFFLINE_BATCHES=1000

# Agent1
AGENT1_HIDDEN=256,128
AGENT1_LR=0.001
AGENT1_GAMMA=0.95
AGENT1_EPSILON_START=0.30
AGENT1_EPSILON_END=0.05
AGENT1_EPSILON_DECAY=10000
AGENT1_BATCH_SIZE=64
AGENT1_BUFFER_SIZE=50000
AGENT1_TARGET_UPDATE=1000
AGENT1_DEADLINE_PENALTY=10.0

# Agent2
AGENT2_HIDDEN=256,128
AGENT2_LR=0.001
AGENT2_GAMMA=0.95
AGENT2_EPSILON_START=0.25
AGENT2_EPSILON_END=0.05
AGENT2_EPSILON_DECAY=8000
AGENT2_BATCH_SIZE=64
AGENT2_BUFFER_SIZE=50000
AGENT2_TARGET_UPDATE=1000
AGENT2_PACKET_DROP_PENALTY=50.0
AGENT2_PREINSTALL_BONUS=0.3

# Bootstrap pretraining
ENABLE_BOOTSTRAP_PRETRAIN=true
BOOTSTRAP_TASKS=8
BOOTSTRAP_NSGA_POP_SIZE=20
BOOTSTRAP_NSGA_GENS=10
BOOTSTRAP_MAX_SECONDS=12.0

# Storage backends (non-breaking, optional)
ENABLE_REDIS_STATE=false
REDIS_URL=redis://localhost:6379/0
ENABLE_POSTGRES_HISTORY=false
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/smart_city
STORE_BATCH_SIZE=100
STORE_FLUSH_INTERVAL_S=1.0
